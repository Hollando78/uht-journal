---
interface Props {
  title: string;
  systemName: string;
}

const { title, systemName } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Newsreader:ital,opsz,wght@0,6..72,400;0,6..72,500;0,6..72,600;0,6..72,700;1,6..72,400&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet" />
    <style>
      :root {
        --bg: #0c0e13;
        --bg-elevated: #12151c;
        --bg-surface: #181c25;
        --bg-hover: #1e2230;
        --text: #d4d4dc;
        --text-bright: #eeeef2;
        --text-muted: #6b7084;
        --text-faint: #454a5e;
        --accent: #c9a24d;
        --accent-dim: #a07d2e;
        --blue: #6b8adb;
        --green: #5a9e6f;
        --red: #c06060;
        --border: #1e2230;
        --border-accent: #2a2d3a;
        --serif: 'Newsreader', 'Georgia', serif;
        --mono: 'JetBrains Mono', 'SF Mono', 'Fira Code', monospace;
        --radius: 4px;
      }

      * { margin: 0; padding: 0; box-sizing: border-box; }

      html {
        font-family: var(--mono);
        background: var(--bg);
        color: var(--text);
        font-size: 14px;
        line-height: 1.7;
        -webkit-font-smoothing: antialiased;
      }

      body { min-height: 100vh; }

      .report-wrapper {
        max-width: 900px;
        width: 100%;
        margin: 0 auto;
        padding: 2rem 2rem 4rem;
      }

      /* Download bar */
      .download-bar {
        position: sticky;
        top: 0;
        z-index: 50;
        background: var(--bg-elevated);
        border-bottom: 1px solid var(--border);
        padding: 0.75rem 2rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
      }

      .download-bar a {
        color: var(--accent);
        text-decoration: none;
        font-size: 0.78rem;
      }

      .download-btn {
        padding: 0.4rem 1rem;
        background: var(--accent-dim);
        color: var(--bg);
        border: none;
        border-radius: var(--radius);
        font-family: var(--mono);
        font-size: 0.75rem;
        font-weight: 600;
        cursor: pointer;
        letter-spacing: 0.04em;
        text-transform: uppercase;
      }

      .download-btn:hover {
        background: var(--accent);
      }

      /* Title block */
      .report-title {
        font-family: var(--serif);
        font-size: 2rem;
        font-weight: 700;
        color: var(--text-bright);
        margin-bottom: 0.5rem;
        letter-spacing: -0.02em;
      }

      .report-subtitle {
        font-size: 0.8rem;
        color: var(--text-muted);
        margin-bottom: 2rem;
      }

      /* Sections */
      h2 {
        font-family: var(--serif);
        font-size: 1.35rem;
        font-weight: 600;
        color: var(--text-bright);
        margin: 2.5rem 0 1rem;
        padding-bottom: 0.5rem;
        border-bottom: 1px solid var(--border);
        letter-spacing: -0.01em;
      }

      h3 {
        font-size: 0.85rem;
        font-weight: 600;
        color: var(--accent);
        margin: 1.5rem 0 0.5rem;
        text-transform: uppercase;
        letter-spacing: 0.06em;
      }

      p {
        margin-bottom: 0.75rem;
        color: var(--text);
        font-size: 0.82rem;
      }

      /* Stats grid */
      .stats-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
        gap: 1rem;
        margin: 1.5rem 0;
      }

      .stat-card {
        background: var(--bg-surface);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 1rem;
        text-align: center;
      }

      .stat-card .value {
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--accent);
        font-variant-numeric: tabular-nums;
      }

      .stat-card .label {
        font-size: 0.65rem;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--text-faint);
        margin-top: 0.25rem;
      }

      /* Tables */
      .req-table {
        width: 100%;
        border-collapse: collapse;
        margin: 1rem 0 2rem;
        font-size: 0.78rem;
      }

      .req-table th {
        text-align: left;
        padding: 0.6rem 0.75rem;
        background: var(--bg-surface);
        color: var(--text-muted);
        font-size: 0.68rem;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        border-bottom: 2px solid var(--border-accent);
        font-weight: 600;
      }

      .req-table td {
        padding: 0.5rem 0.75rem;
        border-bottom: 1px solid var(--border);
        vertical-align: top;
        color: var(--text);
      }

      .req-table tr:hover td {
        background: var(--bg-hover);
      }

      .req-ref {
        font-weight: 600;
        color: var(--accent);
        white-space: nowrap;
        font-size: 0.72rem;
      }

      .req-tags {
        font-size: 0.68rem;
        color: var(--text-faint);
      }

      .hex-code {
        font-family: var(--mono);
        color: var(--accent);
        font-weight: 600;
      }

      /* Decomposition tree */
      .decomp-tree {
        list-style: none;
        padding-left: 0;
      }

      .decomp-tree li {
        padding: 0.3rem 0;
        font-size: 0.8rem;
      }

      .decomp-tree ul {
        list-style: none;
        padding-left: 1.5rem;
        border-left: 1px solid var(--border);
        margin-left: 0.5rem;
      }

      .decomp-tree .node-name {
        color: var(--text-bright);
        font-weight: 500;
      }

      .decomp-tree .node-hex {
        color: var(--accent-dim);
        font-size: 0.72rem;
        margin-left: 0.5rem;
      }

      /* Mermaid */
      .mermaid-container {
        margin: 1.5rem 0;
        padding: 1rem;
        background: var(--bg-elevated);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        overflow-x: auto;
        text-align: center;
      }

      .mermaid-container svg { max-width: 100%; height: auto; }

      .diagram-caption {
        font-size: 0.72rem;
        color: var(--text-faint);
        text-align: center;
        margin-top: 0.5rem;
        font-style: italic;
      }

      /* Entity table */
      .entity-table {
        width: 100%;
        border-collapse: collapse;
        margin: 1rem 0;
        font-size: 0.75rem;
      }

      .entity-table th {
        text-align: left;
        padding: 0.5rem 0.6rem;
        background: var(--bg-surface);
        color: var(--text-muted);
        font-size: 0.65rem;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        border-bottom: 2px solid var(--border-accent);
        font-weight: 600;
      }

      .entity-table td {
        padding: 0.4rem 0.6rem;
        border-bottom: 1px solid var(--border);
        vertical-align: top;
      }

      .entity-table tr:hover td { background: var(--bg-hover); }

      /* Facts table */
      .fact-table {
        width: 100%;
        border-collapse: collapse;
        margin: 1rem 0;
        font-size: 0.75rem;
      }

      .fact-table th {
        text-align: left;
        padding: 0.5rem 0.6rem;
        background: var(--bg-surface);
        color: var(--text-muted);
        font-size: 0.65rem;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        border-bottom: 2px solid var(--border-accent);
        font-weight: 600;
      }

      .fact-table td {
        padding: 0.4rem 0.6rem;
        border-bottom: 1px solid var(--border);
      }

      /* Print styles */
      @media print {
        :root {
          --bg: #fff;
          --bg-elevated: #f8f8f8;
          --bg-surface: #f0f0f0;
          --bg-hover: #f5f5f5;
          --text: #111;
          --text-bright: #000;
          --text-muted: #555;
          --text-faint: #888;
          --accent: #1a3a6b;
          --accent-dim: #2a5a9b;
          --border: #ddd;
          --border-accent: #ccc;
        }

        .download-bar { display: none !important; }

        html { font-size: 11px; }

        .report-wrapper { padding: 0; max-width: 100%; }

        h2 { page-break-after: avoid; margin-top: 1.5rem; }

        .req-table, .entity-table, .fact-table {
          page-break-inside: auto;
        }

        .req-table tr, .entity-table tr, .fact-table tr {
          page-break-inside: avoid;
        }

        .mermaid-container {
          background: #fff;
          border: 1px solid #ccc;
          print-color-adjust: exact;
          -webkit-print-color-adjust: exact;
        }

        .stat-card {
          background: #f5f5f5;
          border: 1px solid #ddd;
          print-color-adjust: exact;
          -webkit-print-color-adjust: exact;
        }

        @page {
          margin: 1.5cm;
          size: A4;
        }
      }

      @media (max-width: 600px) {
        .report-wrapper { padding: 1rem; }
        .stats-grid { grid-template-columns: repeat(2, 1fr); }
        .req-table { font-size: 0.7rem; }
      }
    </style>
  </head>
  <body>
    <div class="download-bar">
      <a href="/reports">&larr; All reports</a>
      <button class="download-btn" onclick="window.print()">Download PDF</button>
    </div>
    <div class="report-wrapper">
      <slot />
    </div>
    <script is:inline>
    (function() {
      var pres = document.querySelectorAll('.mermaid-container pre.mermaid-src');
      if (pres.length === 0) return;
      pres.forEach(function(pre) {
        var div = document.createElement('pre');
        div.className = 'mermaid';
        div.textContent = pre.textContent.trim();
        pre.parentNode.replaceChild(div, pre);
      });
      var s = document.createElement('script');
      s.src = 'https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.min.js';
      s.onload = function() {
        window.mermaid.initialize({
          startOnLoad: false,
          theme: 'dark',
          themeVariables: {
            primaryColor: '#1e2230',
            primaryTextColor: '#d4d4dc',
            primaryBorderColor: '#2a2d3a',
            lineColor: '#6b7084',
            secondaryColor: '#181c25',
            tertiaryColor: '#12151c',
            fontFamily: "'JetBrains Mono', monospace",
            fontSize: '12px'
          }
        });
        window.mermaid.run({ querySelector: '.mermaid' });
      };
      document.head.appendChild(s);
    })();
    </script>
  </body>
</html>
